# Riddle 运行时配置模板。复制成本地 .env 后按需填写。
# cp .env.example .env  &&  nano .env
# 本文件可提交版本库;.env(真实密钥)不可提交,已在 .gitignore。

# 监听端口。默认 80(需 root);公网常用 9000 等高位端口。
RIDDLE_PORT=9000

# --- LLM 接入(OpenAI 兼容视觉端点) -----------------------------------
# 留空 KEY 则日记回落到内置离线 mock(纯本地玩手写动画)。
RIDDLE_OPENAI_BASE=https://integrate.api.nvidia.com/v1
RIDDLE_OPENAI_KEY=
# 必须是视觉模型才能看懂你写在纸上的字;中文手写优先 qwen/qwen2.5-vl-72b-instruct
RIDDLE_OPENAI_MODEL=meta/llama-3.2-11b-vision-instruct

# --- 访问令牌(进日记的钥匙) -------------------------------------------
# 旧式后门令牌:一把长随机串。持此串者可进日记;前后台 U 不删它。
# 留空即靠后台 /admin 生成的钥匙进,更推荐。
RIDDLE_ACCESS_TOKEN=

# --- 后台 /admin 登录(生成/删除访问钥匙、改账号密码) ------------------
# 部署后务必改成强密码;改密会原地改写本文件并重启服务。
RIDDLE_ADMIN_USER=admin
RIDDLE_ADMIN_PASS=请换成你自己的强密码
